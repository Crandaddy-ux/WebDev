---
import Navigation from './Navigation.astro';

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = 'Welcome to WebDev', 
  subtitle = 'Build amazing websites with Astro' 
} = Astro.props;
---

<header class="header">
  <Navigation />
  <div class="hero">
    <div class="hero-content">
      <h1>{title}</h1>
      <p>{subtitle}</p>
      <a href="#projects" class="cta-button">Get Started</a>
    </div>
  </div>
</header>

<style>
  .header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    text-align: center;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    margin: 0 0 1rem 0;
    font-weight: bold;
  }

  .hero-content p {
    font-size: 1.25rem;
    margin: 0 0 2rem 0;
    opacity: 0.9;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2rem;
    background-color: #4CAF50;
    color: white;
    text-decoration: none;
    border-radius: 5px;
    transition: background-color 0.3s ease;
    font-weight: bold;
  }

  .cta-button:hover {
    background-color: #45a049;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }

    .hero-content p {
      font-size: 1rem;
    }

    .hero {
      padding: 2rem 1rem;
    }
  }
</style>
